<Window x:Class="AdminDiskApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AdminDiskApp.ViewModels"
        Title="{Binding WindowTitle}" Height="650" Width="950">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="150" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="➕ Přidat složku" Command="{Binding AddFolderCommand}" Padding="15,8" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <TextBlock Text="⏰ Automaticky v:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Text="{Binding ScheduledTime}" Width="60" VerticalAlignment="Center" Padding="5" TextAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <DataGrid ItemsSource="{Binding Tasks}" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Adresář" Binding="{Binding FolderPath}" Width="*" IsReadOnly="True" />
                <DataGridTextColumn Header="Filtr" Binding="{Binding Filter}" Width="80" />
                <DataGridTextColumn Header="Dní" Binding="{Binding DaysOld}" Width="60" />
                <DataGridCheckBoxColumn Header="Sub" Binding="{Binding Recursive}" Width="50"/>
                <DataGridCheckBoxColumn Header="On" Binding="{Binding IsEnabled}" Width="50"/>
                <DataGridTemplateColumn Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑" Command="{Binding DataContext.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="Red" Background="Transparent" BorderBrush="Transparent" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Expander Header="Nastavení a Windows Automatizace" Grid.Row="2" Margin="0,10,0,0">
            <StackPanel Margin="10" Background="#F9F9F9">
                <Button Content="ZAREGISTROVAT DO PLÁNOVAČE ÚLOH WINDOWS" 
                Command="{Binding RegisterTaskCommand}" 
                Padding="10,5" />
                <TextBlock Text="Tip: Aplikace se po registraci spustí automaticky na pozadí." 
                   FontSize="10" Foreground="Gray" Margin="0,5,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Expander>

        <TextBox Text="{Binding LogOutput}" Grid.Row="3" Margin="0,10,0,0" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#1E1E1E" Foreground="#DCDCDC" FontFamily="Consolas" />

        <Button Content="SPUSTIT RUČNÍ ÚKLID" Command="{Binding RunAllTasksCommand}" Grid.Row="4" Height="50" Margin="0,10,0,0" Background="#28a745" Foreground="White" FontWeight="Bold" />
    </Grid>
</Window>