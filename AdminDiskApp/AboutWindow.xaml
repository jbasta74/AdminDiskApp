<Window x:Class="AdminDiskApp.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="O aplikaci" Height="280" Width="420"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize" 
        ShowInTaskbar="False"
        Background="#F3F3F3">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Image Source="app_icon.ico" Grid.Column="0" Width="64" Height="64" VerticalAlignment="Top" Margin="0,0,20,0"/>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="AdminDiskApp" FontSize="20" FontWeight="Bold" Foreground="#007ACC" />
                <TextBlock x:Name="VersionText" Text="Verze 1.0.0" Margin="0,5,0,10" Foreground="Gray" />

                <TextBlock Text="Nástroj pro automatizovanou údržbu disků a čistění starých záloh na serverech." 
                           TextWrapping="Wrap" Margin="0,0,0,10" />

                <TextBlock Text="© 2026 Jiří Bašta" FontWeight="SemiBold" Margin="0,0,0,5" />

                <TextBlock>
                    <Hyperlink NavigateUri="https://github.com/jbasta74/AdminDiskApp" 
                               RequestNavigate="Hyperlink_RequestNavigate">
                        GitHub Projekt
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <Button Grid.Row="1" Content="Zavřít" IsDefault="True" Click="Close_Click" 
                    HorizontalAlignment="Right" Width="80" Padding="5"/>
        </Grid>
    </Grid>
</Window>